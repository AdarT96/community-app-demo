GEMINI_API_KEY=AIzaSy-your-server-key-here
PORT=3000

# Environment
NODE_ENV=development

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,capacitor://localhost,ionic://localhost

# Gemini model allowlist (comma-separated)
ALLOWED_GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Basic API protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
BODY_LIMIT=64kb
